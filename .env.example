# ============================================================
# AI Native 互动游戏平台 — 环境变量配置模板
# ============================================================
# 使用方法：复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# 本文件包含全部 18 个环境变量，按功能分为 6 组：
#   Database (1) | Redis (1) | MinIO/S3 (5) | JWT (3) | LLM (4) | Frontend (2)
#   Docker Compose 额外注入 1 个：CORS_ORIGINS
# ============================================================

# --- 数据库 ---
# SQLite（开发环境，零配置，单文件数据库）：
DATABASE_URL=sqlite+aiosqlite:///./app.db
# PostgreSQL（生产环境，支持并发写入）：
# DATABASE_URL=postgresql+asyncpg://用户名:密码@主机:5432/数据库名

# --- Redis（Celery 消息代理 + 任务结果后端）---
# 开发环境：端口 6380 避免与本地 Redis 冲突
# 生产环境：改为你的 Redis 服务地址
REDIS_URL=redis://localhost:6380/0
#                              |        |
#                              |        └─ 数据库编号 0（Redis 支持 0-15 共 16 个数据库）
#                              └─ 端口 6380（docker-compose.yml 映射端口）

# --- MinIO 对象存储（开发环境） / 阿里云 OSS（生产环境）---
# 【为什么 boto3 迁移后仍然维持 MINIO_ 前缀？】
#   早期版本使用 minio-py SDK，环境变量命名为 MINIO_*。
#   迁移到 boto3（AWS SDK for Python）后，底层库完全换了，
#   但环境变量名作为外部配置接口没有改变：
#     1. 已有的 .env 文件、docker-compose.yml、Railway 密钥、
#        CI/CD 配置等多个地方引用 MINIO_ 前缀名称
#     2. boto3 本身不读取环境变量前缀 —— botocore 的 session/client
#        需要显式传参（endpoint_url、aws_access_key_id 等），
#        前缀完全由应用层代码定义（见 backend/app/config.py）
#     3. 代码中 settings.minio_endpoint 内部封装，修改前缀只需改
#        config.py 的 alias，但对外接口约定保持 MINIO_ 不变
#     4. 核心设计原则：环境变量是配置的外部接口，不应因内部
#        实现变更而破坏——这是依赖倒置的体现
#   结论：MINIO_ 作为项目约定的配置前缀，与底层 SDK 解耦
MINIO_ENDPOINT=localhost:9000
#              生产环境替换为你的 S3 兼容 endpoint：
#              阿里云 OSS: oss-cn-{region}.aliyuncs.com
#              Cloudflare R2: {account_id}.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=minioadmin
#                 MinIO 开发默认值，生产环境务必修改
#                 阿里云 OSS 使用你的 AccessKey ID
MINIO_SECRET_KEY=minioadmin
#                 MinIO 开发默认值，生产环境务必修改
#                 阿里云 OSS 使用你的 AccessKey Secret
MINIO_BUCKET=ai-game-platform
#            存储桶名称（S3/OSS 中称为 Bucket）
#            游戏 HTML 文件路径格式：games/{uuid}/index.html
MINIO_SECURE=false
#              false: 使用 HTTP（MinIO 开发环境默认）
#              true:  使用 HTTPS（阿里云 OSS / AWS S3 生产环境）

# --- JWT 认证 ---
# 【安全警告】以下密钥仅用于开发！
# 生产环境必须替换为强随机字符串：
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-production-use-a-random-64-character-string
#          HS256 签名密钥，长度随意但建议 >= 256 bits
#          泄露后果：攻击者可伪造任意用户 Token
JWT_ALGORITHM=HS256
#              对称加密算法，适合单服务场景
#              RS256（非对称）适合微服务架构，需配置公钥/私钥对
JWT_EXPIRE_MINUTES=1440
#                    1440 分钟 = 24 小时
#                    Token 过期后用户需重新登录，平衡安全与体验

# --- LLM 配置 ---
# 【LLM_PROVIDER 支持的选项】
#   claude     → Anthropic Claude (api.anthropic.com)
#   openai     → OpenAI GPT (api.openai.com)
#   deepseek   → DeepSeek (api.deepseek.com)，性价比最高的中文模型
#   none       → 禁用 AI 生成功能（游戏列表仍可正常使用）
LLM_PROVIDER=deepseek
#            环境变量值流向：config.py → llm_adapter.py（工厂模式匹配）

LLM_API_KEY=sk-your-deepseek-api-key
#            替换为你的 DeepSeek API Key
#            获取地址：https://platform.deepseek.com/api_keys
#            安全提示：永远不要提交包含真实 Key 的 .env 文件到 Git

LLM_MODEL=deepseek-chat
#          使用的模型名称：
#          deepseek-chat  → 通用对话模型（推荐）
#          deepseek-coder → 代码生成专用（备选）
#          当 LLM_PROVIDER=openai 时设为 gpt-4o 等

# 可选：自定义 API 端点（用于 OpenAI 兼容的第三方 API）
# LLM_API_BASE_URL=https://api.deepseek.com
#                       DeepSeek 使用 OpenAI 兼容格式，
#                       通过 base_url 切换无需修改代码逻辑

# --- 前端（Vite 构建时使用）---
VITE_API_URL=http://localhost:8000
#            前端请求的 API 基础 URL
#            开发环境：localhost:8000（Vite proxy 转发到此地址）
#            生产环境：实际部署域名
VITE_MINIO_URL=http://localhost:9000
#               MinIO 公网访问地址
#               用于前端直接加载存储在 MinIO 中的资源
