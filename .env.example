# ============================================
# AI Native Game Platform — Environment Config
# ============================================
# Copy this file to .env and fill in your values.

# --- Database ---
# SQLite (dev, zero config):
DATABASE_URL=sqlite+aiosqlite:///./app.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://aigame:aigame@localhost:5432/aigame

# --- Redis (Celery broker) ---
REDIS_URL=redis://localhost:6380/0

# --- MinIO Object Storage ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-game-platform
MINIO_SECURE=false

# --- JWT ---
JWT_SECRET=change-me-in-production-use-a-random-64-character-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- LLM Configuration ---
# Provider: "claude" | "openai" | "deepseek" | "none"
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat
# Optional: custom endpoint for OpenAI-compatible APIs
# LLM_API_BASE_URL=https://api.deepseek.com

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_MINIO_URL=http://localhost:9000
